# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only: used by lib/match-actions.ts to write money-adjacent columns
# (stake confirmation, settlement) that RLS blocks from direct client writes.
# Never expose this to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Staked multiplayer escrow mode: "mock" (default, no Stellar dependency) or
# "live" (requires lib/soroban/trustlessWorkEscrowClient.ts, not yet implemented).
NEXT_PUBLIC_ESCROW_MODE=mock
